{
  "name": "webview-kiosk",
  "main": "src/cloudflare-worker.js",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "404-page",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }
}
